#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = [
#   "requests==2.34.2",
# ]
# ///
"""
Trigger and optionally download UniFi OS backups.

Backup types (--type):
  network  Trigger a Network application backup (.unf). Optionally download.
             Trigger:  POST /proxy/network/api/s/{site}/cmd/backup
             Download: GET  /proxy/network/dl/backup/{filename}
  system   Trigger and download a full UniFi OS system backup (.unifi).
             Download: GET  /api/backup/download  (triggers and streams in one shot)

Authentication:
  --api-key   Stateless. Sent as X-API-Key header. No login/logout/CSRF.
              Only works for network backups — API keys are scoped to the Network application.
  --user/pass Cookie session with CSRF token. Works for all backup types.
              Required for system and both types.

Environment variables:
  UNIFI_HOST        Controller hostname/IP
  UNIFI_PORT        Controller port (default: 443)
  UNIFI_API_KEY     API key (preferred)
  UNIFI_USER        Admin username
  UNIFI_PASS        Admin password
  UNIFI_SITE        Site name (default: default)
  UNIFI_VERIFY_SSL  Set to "true" to verify TLS cert (default: false)
  UNIFI_TYPE        Backup type: network, system, or both (default: network)
  UNIFI_DOWNLOAD    Set to "true" to download after triggering (network type only)
  UNIFI_OUTDIR      Directory to save downloaded backup (default: .)
  UNIFI_DAYS        Days of events to include in network backup (-1 = all, default: -1)
"""

import argparse
import os
import sys
import json
import logging
from datetime import datetime
from pathlib import Path
from urllib.parse import urljoin

import requests
from requests.packages.urllib3.exceptions import InsecureRequestWarning

logging.basicConfig(level=logging.INFO, format="%(asctime)s %(levelname)s %(message)s")
log = logging.getLogger("unifi-backup")


def parse_args() -> argparse.Namespace:
    p = argparse.ArgumentParser(
        description="Trigger and optionally download UniFi OS backups.",
        formatter_class=argparse.ArgumentDefaultsHelpFormatter,
    )
    p.add_argument("--host",       default=os.getenv("UNIFI_HOST"),                                    help="Controller hostname or IP")
    p.add_argument("--port",       default=int(os.getenv("UNIFI_PORT", "443")), type=int,              help="Controller HTTPS port")
    p.add_argument("--api-key",    default=os.getenv("UNIFI_API_KEY"),                                 help="API key (takes priority over user/pass)")
    p.add_argument("--user",       default=os.getenv("UNIFI_USER"),                                    help="Admin username")
    p.add_argument("--password",   default=os.getenv("UNIFI_PASS"),                                    help="Admin password")
    p.add_argument("--site",       default=os.getenv("UNIFI_SITE", "default"),                         help="Site name (network type only)")
    p.add_argument("--verify-ssl", action="store_true",
                   default=os.getenv("UNIFI_VERIFY_SSL", "false").lower() == "true",                   help="Verify TLS certificate")
    p.add_argument("--type",       default=os.getenv("UNIFI_TYPE", "network"), choices=["network", "system", "both"],
                                                                                                        help="Backup type")
    p.add_argument("--download",   action="store_true",
                   default=os.getenv("UNIFI_DOWNLOAD", "false").lower() == "true",                     help="Download after triggering (network type only; system always downloads)")
    p.add_argument("--outdir",     default=os.getenv("UNIFI_OUTDIR", "."),                             help="Directory to save downloaded backup")
    p.add_argument("--days",       default=int(os.getenv("UNIFI_DAYS", "-1")), type=int,               help="Days of events to include in network backup (-1 = all)")
    return p.parse_args()


def validate_config(args: argparse.Namespace) -> None:
    errors = []
    if not args.host:
        errors.append("--host / UNIFI_HOST is required")
    if not args.api_key and not (args.user and args.password):
        errors.append("provide --api-key or both --user and --password")
    if args.api_key and args.type in ("system", "both"):
        errors.append("--type system/both requires --user and --password (API keys are scoped to the Network application)")
    for e in errors:
        log.error(e)
    if errors:
        sys.exit(1)


class UniFiOSClient:
    def __init__(self, host: str, port: int, verify_ssl: bool, api_key: str | None = None):
        self.base_url = f"https://{host}:{port}"
        self.session = requests.Session()
        self.session.verify = verify_ssl

        if not verify_ssl:
            requests.packages.urllib3.disable_warnings(InsecureRequestWarning)

        if api_key:
            self.session.headers.update({"X-API-Key": api_key})

    def _url(self, path: str) -> str:
        return urljoin(self.base_url, path)

    def login(self, username: str, password: str) -> None:
        log.info("Logging in to %s as '%s'", self.base_url, username)
        try:
            resp = self.session.post(
                self._url("/api/auth/login"),
                json={"username": username, "password": password},
                timeout=30,
            )
        except requests.exceptions.ConnectionError as exc:
            log.error("Connection failed: %s", exc)
            sys.exit(1)
        except requests.exceptions.Timeout:
            log.error("Connection timed out")
            sys.exit(1)

        if resp.status_code == 499:
            log.error("2FA is enabled on this account — not supported.")
            sys.exit(1)
        if resp.status_code != 200:
            log.error("Login failed: HTTP %s — %s", resp.status_code, resp.text[:200])
            sys.exit(1)

        csrf = resp.headers.get("X-CSRF-Token") or self.session.cookies.get("TOKEN")
        if not csrf:
            log.warning("CSRF token not found — mutating requests may fail.")
        else:
            self.session.headers.update({"X-CSRF-Token": csrf})

        log.info("Login successful")

    def logout(self) -> None:
        try:
            self.session.post(self._url("/api/auth/logout"), timeout=15)
        except Exception:
            pass
        log.info("Logged out")

    def _stream_to_file(self, resp: requests.Response, dest: Path) -> Path | None:
        """Write a streaming response to dest, with content-type guard."""
        content_type = resp.headers.get("Content-Type", "")
        if "text/html" in content_type:
            log.error("Download returned HTML — authentication failed for this path.")
            return None

        with open(dest, "wb") as f:
            for chunk in resp.iter_content(chunk_size=65536):
                f.write(chunk)

        log.info("Saved %d bytes to %s", dest.stat().st_size, dest)
        return dest

    # -- Network backup ------------------------------------------------------

    def trigger_network_backup(self, site: str, days: int = -1) -> str | None:
        """Returns the server-side file path if provided, otherwise None."""
        log.info("Triggering network backup for site '%s' (days=%s)…", site, days)
        try:
            resp = self.session.post(
                self._url(f"/proxy/network/api/s/{site}/cmd/backup"),
                json={"cmd": "backup", "days": days},
                timeout=120,
            )
        except requests.exceptions.Timeout:
            log.error("Backup request timed out — the controller may still be generating it.")
            return None

        if resp.status_code != 200:
            log.error("Backup trigger failed: HTTP %s — %s", resp.status_code, resp.text[:300])
            return None

        data = resp.json()
        if data.get("meta", {}).get("rc") != "ok":
            log.error("Backup API error: %s", json.dumps(data, indent=2))
            return None

        result_data = data.get("data", [])
        url_path = result_data[0].get("url") if result_data else None
        if url_path:
            log.info("Backup written to: %s", url_path)

        log.info("Backup triggered successfully")
        return url_path

    def download_network_backup(self, url_path: str, outdir: str) -> Path | None:
        """Download via /proxy/network/dl/backup/{filename}."""
        if not url_path.startswith("/proxy/network"):
            url_path = f"/proxy/network{url_path}"

        outdir_path = Path(outdir)
        outdir_path.mkdir(parents=True, exist_ok=True)
        dest = outdir_path / f"{datetime.now().strftime('%Y%m%d_%H%M%S')}_{Path(url_path).name}"

        full_url = self._url(url_path)
        log.info("Downloading network backup from %s …", full_url)
        try:
            resp = self.session.get(full_url, stream=True, timeout=120, allow_redirects=False)
        except requests.exceptions.Timeout:
            log.error("Download timed out")
            return None

        if resp.status_code != 200:
            log.error("Download failed: HTTP %s", resp.status_code)
            return None

        return self._stream_to_file(resp, dest)

    # -- System backup -------------------------------------------------------

    def download_system_backup(self, outdir: str) -> Path | None:
        """GET /api/backup/download — triggers and streams the system backup in one shot."""
        outdir_path = Path(outdir)
        outdir_path.mkdir(parents=True, exist_ok=True)

        full_url = self._url("/api/backup/download")
        log.info("Downloading system backup from %s …", full_url)
        try:
            resp = self.session.get(full_url, stream=True, timeout=300, allow_redirects=False)
        except requests.exceptions.Timeout:
            log.error("Download timed out")
            return None

        if resp.status_code != 200:
            log.error("Download failed: HTTP %s", resp.status_code)
            return None

        # Use the filename header the controller provides, fall back to a datestamped name
        server_filename = (
            resp.headers.get("filename")
            or resp.headers.get("Content-Disposition", "").split("filename=")[-1].strip('" ')
            or None
        )
        filename = f"{datetime.now().strftime('%Y%m%d_%H%M%S')}_{server_filename}" if server_filename \
            else f"{datetime.now().strftime('%Y%m%d_%H%M%S')}_unifi_system_backup.unifi"
        dest = outdir_path / filename

        return self._stream_to_file(resp, dest)


def main() -> None:
    args = parse_args()
    validate_config(args)

    client = UniFiOSClient(
        host=args.host,
        port=args.port,
        verify_ssl=args.verify_ssl,
        api_key=args.api_key or None,
    )

    using_api_key = bool(args.api_key)
    try:
        if not using_api_key:
            client.login(args.user, args.password)

        if args.type in ("network", "both"):
            url_path = client.trigger_network_backup(site=args.site, days=args.days)
            if args.download or args.type == "both":
                if not url_path:
                    log.error("Cannot download — controller did not return a file path.")
                    sys.exit(1)
                if not client.download_network_backup(url_path, args.outdir):
                    sys.exit(1)

        if args.type in ("system", "both"):
            if not client.download_system_backup(args.outdir):
                sys.exit(1)

    finally:
        if not using_api_key:
            client.logout()


if __name__ == "__main__":
    main()
